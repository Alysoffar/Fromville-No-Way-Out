      "text": "It knows my name!",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\panic_female\\08_it_knows_my_name.wav"
    },
    {
      "group": "panic_female",
      "text": "The talisman, get to the talisman!",
