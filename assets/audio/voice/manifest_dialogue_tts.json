    },
    {
      "group": "npc_male_general",
      "text": "The monsters smile like they know us.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\24_the_monsters_smile_like_they_know_us.wav"
    },
    {
      "group": "npc_male_general",
      "text": "I saw something watching from the second floor.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\25_i_saw_something_watching_from_the_second.wav"
    },
    {
      "group": "npc_male_general",
      "text": "The diner is safer if we move before dark.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\26_the_diner_is_safer_if_we_move_before_dar.wav"
    },
    {
      "group": "npc_male_general",
      "text": "Somebody needs to check the windows.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\27_somebody_needs_to_check_the_windows.wav"
    },
    {
      "group": "npc_male_general",
      "text": "The tunnels are whispering again.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\28_the_tunnels_are_whispering_again.wav"
    },
    {
      "group": "npc_male_general",
      "text": "The town feels like it moved overnight.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\29_the_town_feels_like_it_moved_overnight.wav"
    },
    {
      "group": "npc_male_general",
      "text": "If you hear music, do not follow it.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\30_if_you_hear_music_do_not_follow_it.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "Did you lock the back door?",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\01_did_you_lock_the_back_door.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "The lamps near the road went out again.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\02_the_lamps_near_the_road_went_out_again.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "I counted three of them before sunrise.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\03_i_counted_three_of_them_before_sunrise.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "Keep everyone away from the tree line.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\04_keep_everyone_away_from_the_tree_line.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "The diner still has supplies if we hurry.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\05_the_diner_still_has_supplies_if_we_hurry.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "I heard knocking from the empty house.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\06_i_heard_knocking_from_the_empty_house.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "Nobody sleeps near a window tonight.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\07_nobody_sleeps_near_a_window_tonight.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "If you see a child outside, call Boyd first.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\08_if_you_see_a_child_outside_call_boyd_fir.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "The church bell rang but nobody was there.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\09_the_church_bell_rang_but_nobody_was_ther.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "Something copied my voice yesterday.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\10_something_copied_my_voice_yesterday.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "We move together when it gets dark.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\11_we_move_together_when_it_gets_dark.wav"
    },
    {
      "group": "npc_male_neighbor",
      "text": "Tom said the road signs changed again.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\npc_male\\12_tom_said_the_road_signs_changed_again.wav"
    },
    {
      "group": "npc_replies",
      "text": "I will check it. Stay where I can see you.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\01_i_will_check_it_stay_where_i_can_see_you.wav"
    },
    {
      "group": "npc_replies",
      "text": "Nobody wanders off. Not tonight.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\02_nobody_wanders_off_not_tonight.wav"
    },
    {
      "group": "npc_replies",
      "text": "Tell me exactly what you heard.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\03_tell_me_exactly_what_you_heard.wav"
    },
    {
      "group": "npc_replies",
      "text": "Get inside if the sky starts to turn.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\04_get_inside_if_the_sky_starts_to_turn.wav"
    },
    {
      "group": "npc_replies",
      "text": "We keep calm, then we move.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\05_we_keep_calm_then_we_move.wav"
    },
    {
      "group": "npc_replies",
      "text": "I need names, places, anything useful.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\06_i_need_names_places_anything_useful.wav"
    },
    {
      "group": "npc_replies",
      "text": "That sounds like a pattern, not a coincidence.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\01_that_sounds_like_a_pattern_not_a_coincid.wav"
    },
    {
      "group": "npc_replies",
      "text": "Show me where. I need to compare the symbols.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\02_show_me_where_i_need_to_compare_the_symb.wav"
    },
    {
      "group": "npc_replies",
      "text": "Great. The nightmare has rules and nobody wrote them down.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\03_great_the_nightmare_has_rules_and_nobody.wav"
    },
    {
      "group": "npc_replies",
      "text": "If it repeats, we can use it.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\04_if_it_repeats_we_can_use_it.wav"
    },
    {
      "group": "npc_replies",
      "text": "Static, whispers, lights. It all connects somehow.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\05_static_whispers_lights_it_all_connects_s.wav"
    },
    {
      "group": "npc_replies",
      "text": "Do not touch anything strange until I see it.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\06_do_not_touch_anything_strange_until_i_se.wav"
    },
    {
      "group": "npc_replies",
      "text": "I have seen those signs underground.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\01_i_have_seen_those_signs_underground.wav"
    },
    {
      "group": "npc_replies",
      "text": "If there is a passage, I can find it.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\02_if_there_is_a_passage_i_can_find_it.wav"
    },
    {
      "group": "npc_replies",
      "text": "Keep the children away from the doors.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\03_keep_the_children_away_from_the_doors.wav"
    },
    {
      "group": "npc_replies",
      "text": "The house sounds different when something is below it.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\04_the_house_sounds_different_when_somethin.wav"
    },
    {
      "group": "npc_replies",
      "text": "I know that feeling. The town is hiding spaces.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\05_i_know_that_feeling_the_town_is_hiding_s.wav"
    },
    {
      "group": "npc_replies",
      "text": "Mark the place and do not go back alone.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\06_mark_the_place_and_do_not_go_back_alone.wav"
    },
    {
      "group": "npc_replies",
      "text": "That happened before. I remember the color of the sky.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\01_that_happened_before_i_remember_the_colo.wav"
    },
    {
      "group": "npc_replies",
      "text": "The trees know when people are scared.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\02_the_trees_know_when_people_are_scared.wav"
    },
    {
      "group": "npc_replies",
      "text": "Do not follow the music. It lies.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\03_do_not_follow_the_music_it_lies.wav"
    },
    {
      "group": "npc_replies",
      "text": "I can draw it if you let me think.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\04_i_can_draw_it_if_you_let_me_think.wav"
    },
    {
      "group": "npc_replies",
      "text": "Some places are hungry. You should leave them alone.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\05_some_places_are_hungry_you_should_leave.wav"
    },
    {
      "group": "npc_replies",
      "text": "The town keeps the old things close.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\06_the_town_keeps_the_old_things_close.wav"
    },
    {
      "group": "npc_replies",
      "text": "The voices get louder near places like that.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\01_the_voices_get_louder_near_places_like_t.wav"
    },
    {
      "group": "npc_replies",
      "text": "I am trying to listen without obeying.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\02_i_am_trying_to_listen_without_obeying.wav"
    },
    {
      "group": "npc_replies",
      "text": "If I hear a warning, I will tell you.",
