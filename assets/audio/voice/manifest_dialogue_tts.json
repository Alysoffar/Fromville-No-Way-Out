    },
    {
      "group": "npc_replies",
      "text": "Sometimes the town uses fear like a hook.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\04_sometimes_the_town_uses_fear_like_a_hook.wav"
    },
    {
      "group": "npc_replies",
      "text": "Do not trust anything that says it can save us.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\05_do_not_trust_anything_that_says_it_can_s.wav"
    },
    {
      "group": "npc_replies",
      "text": "I know what it feels like when it calls your name.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\06_i_know_what_it_feels_like_when_it_calls.wav"
    },
    {
      "group": "monster_responses",
      "text": "Boyd: Back up. I am not giving you anyone.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\01_boyd_back_up_i_am_not_giving_you_anyone.wav"
    },
    {
      "group": "monster_responses",
      "text": "Jade: You talk too much for something pretending to be human.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\02_jade_you_talk_too_much_for_something_pre.wav"
    },
    {
      "group": "monster_responses",
      "text": "Tabitha: I know what you are trying to do.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\03_tabitha_i_know_what_you_are_trying_to_do.wav"
    },
    {
      "group": "monster_responses",
      "text": "Victor: I remember you. I remember what comes next.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\04_victor_i_remember_you_i_remember_what_co.wav"
    },
    {
      "group": "monster_responses",
      "text": "Sara: No. I am not listening anymore.",
      "path": "D:\\college work\\term6\\com_graphics\\Fromville\\assets\\audio\\voice\\responses\\05_sara_no_i_am_not_listening_anymore.wav"
    },
    {
